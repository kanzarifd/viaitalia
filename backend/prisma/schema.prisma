generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum AppointmentEtat {
  PRESENTIEL
  EN_LIGNE
}

enum DossierStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum ContractStatus {
  PENDING
  UPLOADED
  CONFIRMED
  REJECTED
}

enum AnnouncementType {
  INFO
  SUCCESS
  WARNING
  URGENT
}

model UniversityInfo {
  id          Int      @id @default(autoincrement())
  university  String
  specialty    String
  level        String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            Int       @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String    @unique
  password      String
  passport      String?
  studyType     String?
  university    String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())

  appointments  Appointment[]
  dossiers      Dossier[]
  payments      Payment[]
  messages      Message[]
  notifications Notification[]
  universityInfo UniversityInfo[]
  contracts     Contract[]
  userAnnouncements UserAnnouncement[]
}

model Appointment {
  id        Int                @id @default(autoincrement())
  type      String
  date      DateTime
  status    AppointmentStatus  @default(PENDING)
  etat      AppointmentEtat    @default(PRESENTIEL)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  createdAt DateTime           @default(now())
}

model Dossier {
  id        Int           @id @default(autoincrement())
  title     String
  status    DossierStatus @default(PENDING)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  createdAt DateTime      @default(now())
}

model Payment {
  id        Int           @id @default(autoincrement())
  amount    Float
  status    PaymentStatus @default(PENDING)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  createdAt DateTime      @default(now())
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  sender    String   // USER or ADMIN
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  createdAt DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  content   String   
  isRead    Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  createdAt DateTime @default(now())
}

model Contract {
  id          Int      @id @default(autoincrement())
  fileName    String
  filePath    String
  status      ContractStatus @default(PENDING)
  user        User     @relation(fields: [userId], references: [id])
  userId     Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Announcement {
  id          Int             @id @default(autoincrement())
  title     String
  content   String
  type      AnnouncementType @default(INFO)
  isActive  Boolean         @default(true)
  link      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  
  userAnnouncements UserAnnouncement[]
}

model UserAnnouncement {
  id            Int         @id @default(autoincrement())
  userId        Int
  announcementId Int
  isRead        Boolean     @default(false)
  createdAt     DateTime    @default(now())
  
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  
  @@unique([userId, announcementId])
}
